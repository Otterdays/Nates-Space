rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // [TRACE: DOCS/SCRATCHPAD.md] Replace REPLACE_WITH_OWNER_FIREBASE_AUTH_UID with your Auth user UID
    // (Firebase Console → Authentication → Users → User UID), then Publish here or run:
    // firebase deploy --only firestore:rules
    match /posts/{postId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.auth.uid == 'REPLACE_WITH_OWNER_FIREBASE_AUTH_UID'
        && request.resource.data.type == 'update'
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 2000
        && request.resource.data.stats is map
        && request.resource.data.stats.likes is int
        && request.resource.data.stats.comments is int
        && request.resource.data.createdAt is timestamp
        && request.resource.data.keys().hasOnly(['type', 'title', 'content', 'stats', 'createdAt']);

      allow update, delete: if request.auth != null
        && request.auth.uid == 'REPLACE_WITH_OWNER_FIREBASE_AUTH_UID';
    }
  }
}
