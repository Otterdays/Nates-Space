rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // [TRACE: DOCS/SCRATCHPAD.md] Replace REPLACE_WITH_OWNER_FIREBASE_AUTH_UID with your Auth user UID
    // (Firebase Console → Authentication → Users → User UID), then Publish here or run:
    // firebase deploy --only firestore:rules
    match /posts/{postId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.auth.uid == '7gTTl2LM8mS2jrByUabHlaRgC4J2'
        && request.resource.data.type == 'update'
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 2000
        && request.resource.data.stats is map
        && request.resource.data.stats.likes is int
        && request.resource.data.stats.comments is int
        && request.resource.data.createdAt is timestamp
        && request.resource.data.keys().hasOnly(['type', 'title', 'content', 'stats', 'createdAt']);

      // Owner: full edit/delete. Anyone: bump stats by at most +1 like OR +1 comment per write.
      allow delete: if request.auth != null
        && request.auth.uid == '7gTTl2LM8mS2jrByUabHlaRgC4J2';

      allow update: if (request.auth != null
          && request.auth.uid == '7gTTl2LM8mS2jrByUabHlaRgC4J2')
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats'])
          && request.resource.data.stats.likes is int
          && request.resource.data.stats.comments is int
          && (
            (
              request.resource.data.stats.likes == resource.data.stats.likes + 1
              && request.resource.data.stats.comments == resource.data.stats.comments
            )
            || (
              request.resource.data.stats.likes == resource.data.stats.likes
              && request.resource.data.stats.comments == resource.data.stats.comments + 1
            )
          )
        );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['text', 'authorName', 'createdAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() <= 120
          && request.resource.data.createdAt is timestamp;
        allow update, delete: if false;
      }
    }
  }
}
